# ═══════════════════════════════════════════════
# AI CSV Importer — Backend Environment Variables
# ═══════════════════════════════════════════════

# Server
PORT=8000

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# CORS
CORS_ORIGIN=http://localhost:3000

# Processing
BATCH_SIZE=25
MAX_RETRIES=3
